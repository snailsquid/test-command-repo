{
  "name": "_akka",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env --watch src/index.ts",
    "start": "bun --env src/index.ts",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "build:admin": "cd admin-ui && bun run build",
    "build:developer": "cd developer-ui && bun run build",
    "build:dashboards": "bun run build:admin && bun run build:developer && cp -r admin-ui/dist/* src/admin/static/ && cp -r developer-ui/dist/* src/developer/static/",
    "build:prod": "bun run build:admin && bun run build:developer"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "vm2": "^3.11.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
